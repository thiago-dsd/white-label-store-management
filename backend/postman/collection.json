{
  "info": {
    "name": "White Label Store Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    }
  ],
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "POST - Criar Cliente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Thiago4882119\",\n  \"clienteDesde\": \"2025-01-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            }
          }
        },
        {
          "name": "GET - Listar Clientes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": ["{{baseUrl}}"],
              "path": ["clientes"]
            }
          }
        },
        {
          "name": "GET - Buscar Cliente por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            }
          }
        },
        {
          "name": "PUT - Atualizar Cliente",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Thiago4882119\",\n  \"clienteDesde\": \"2025-06-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            }
          }
        },
        {
          "name": "DELETE - Remover Cliente",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/clientes/1",
              "host": ["{{baseUrl}}"],
              "path": ["clientes", "1"]
            }
          }
        }
      ]
    },
